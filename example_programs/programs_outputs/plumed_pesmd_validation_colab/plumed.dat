cv: DISTANCE ATOMS=1,2 COMPONENTS
ff: MATHEVAL ARG=cv.x,cv.y FUNC=-200*exp(-1*(x-1)^2-10*(y-0)^2)-100*exp(-1*(x-0)^2-10*(y-0.5)^2)-170*exp(-6.5*(x+0.5)^2+11*(x+0.5)*(y-1.5)-6.5*(y-1.5)^2)+15*exp(0.7*(x+1)^2+0.6*(x+1)*(y-1)+0.7*(y-1)^2) PERIODIC=NO
bb: BIASVALUE ARG=ff
lwall: LOWER_WALLS ARG=cv.x,cv.y AT=-1.5,-0.5 KAPPA=1000.0,1000.0
uwall: UPPER_WALLS ARG=cv.x,cv.y AT=1.5,2.5 KAPPA=1000.0,1000.0
metad: METAD ARG=cv.x,cv.y SIGMA=0.1,0.1 HEIGHT=0.5 PACE=500 FILE=HILLS GRID_MIN=-1.5,-0.5 GRID_MAX=1.5,2.5
PRINT ARG=cv.x,cv.y,ff,metad.bias FILE=COLVAR STRIDE=10
